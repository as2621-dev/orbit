# Orbit environment variables — PLACEHOLDERS ONLY. Never commit real secrets.
# Copy this file to `.env` (which is gitignored) and fill in real values locally.
#
# X (Twitter) cookies — ONLY used when orbit.config.json sets:
#     "cookie_source": "env"
# In every other cookie_source mode (chrome/firefox/safari/edge/brave), Orbit
# reads cookies from your browser via yt-dlp/the X client and these are ignored.
# These values are cookie credentials: they are never logged and never leave your
# machine. Leave blank unless you explicitly use env-based cookies.
AUTH_TOKEN=
CT0=

# WhatsApp delivery (M4 — not yet wired). Uncomment and fill when delivery ships.
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_RECIPIENT=

# WhatsApp delivery via Twilio (M4 optional/stretch). ONLY read when
# orbit.config.json sets delivery.whatsapp_to. These are Twilio credentials: never
# committed, never logged, never transmitted anywhere but Twilio's API. Leave
# commented/blank unless you explicitly enable WhatsApp delivery. PLACEHOLDERS ONLY.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
